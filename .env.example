# Copy this to .env and fill in your values
# Never commit .env to git

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty to use SQLite locally)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Redis (leave empty to run Celery tasks synchronously in dev)
REDIS_URL=

# Flutterwave
FLUTTERWAVE_SECRET_KEY=your-flw-secret-key
FLUTTERWAVE_PUBLIC_KEY=your-flw-public-key
FLUTTERWAVE_SECRET_HASH=your-webhook-secret-hash

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=tickets@yourdomain.com
FROM_NAME=Weekend Events

# Frontend (used in payment redirect URL)
FRONTEND_URL=http://localhost:3000

# CORS (comma-separated for prod)
CORS_ALLOWED_ORIGINS=http://localhost:3000
